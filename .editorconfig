# Editor-agnostic formatting baseline. rustfmt owns Rust style beyond this;
# the frontend has no Prettier (yet), so this is the only shared contract.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,ts,svelte,json,html,css,yml,yaml}]
indent_style = space
indent_size = 2

[*.{rs,py}]
indent_style = space
indent_size = 4

[*.md]
# Trailing double-space is a hard line break in Markdown.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

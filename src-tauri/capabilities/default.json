{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for main and popover windows",
  "windows": ["main", "popover"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "dialog:default",
    "clipboard-manager:allow-write-text",
    "notification:default"
  ]
}

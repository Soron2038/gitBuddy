# ── Node / SvelteKit ──────────────────────────────────────────────
node_modules/
/build
/.svelte-kit
/package
*.tsbuildinfo
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ── Rust / Cargo (Tauri backend) ──────────────────────────────────
# Build artifacts are huge and reproducible from source.
src-tauri/target/
# Cargo.lock is intentionally committed for applications (locks dep versions).

# ── Tauri generated files ─────────────────────────────────────────
src-tauri/gen/
src-tauri/WixTools/

# ── Environment & secrets ─────────────────────────────────────────
.env
.env.*
!.env.example

# ── macOS ─────────────────────────────────────────────────────────
# Note: the classic Finder custom-icon file is literally "Icon\r" (with a
# trailing carriage-return character). A naive `Icon?` glob also matches
# `icons/` on case-insensitive APFS, so we intentionally don't ignore it.
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# ── IDE / editor ──────────────────────────────────────────────────
# Project-shared VS Code config (extensions.json, settings.json) is checked in;
# personal/local overrides should use a *.local.json suffix.
.vscode/*.local.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# ── Claude Code (per-developer assistant state) ───────────────────
# Permission allow-lists are session-specific and shouldn't be shared.
.claude/

# ── Tooling scratch ───────────────────────────────────────────────
# Playwright MCP screenshots/console dumps from local smoke tests.
.playwright-mcp/

# ── Logs & coverage ───────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.nyc_output
coverage/

# ── OS / misc ─────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Build & packaging artifacts ───────────────────────────────────
*.dmg
*.app
*.pkg
*.zip
release/
dist/
__pycache__/
# Updater manifest generated per release by scripts/generate-latest-json.sh
# and uploaded as a GitHub release asset — regenerated each time, never committed.
/latest.json
